# Auth MCP (skip auth for local development)
SKIP_AUTH=true

# Or use API key auth locally:
# MCP_API_KEYS="claude-desktop:mcp_sk_YOUR_KEY_HERE"

# Evernote
EVERNOTE_ACCESS_TOKEN=your_oauth2_access_token_here
EVERNOTE_ENV=sandbox

# Supabase JWT (optional, for JWT auth strategy)
# SB_PUBLISHABLE_KEY=sb_publishable_XXXX
